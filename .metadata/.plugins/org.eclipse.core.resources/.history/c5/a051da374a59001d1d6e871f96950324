package com.shop.app.entity;

import javax.persistence.Column;
import javax.persistence.Entity;
import javax.persistence.GeneratedValue;
import javax.persistence.GenerationType;
import javax.persistence.Id;
import javax.persistence.Table;
import javax.validation.constraints.NotNull;

import lombok.AllArgsConstructor;
import lombok.Data;
import lombok.NoArgsConstructor;

@Data
@AllArgsConstructor
@NoArgsConstructor
@Entity
@Table(name = "Books")
public class Books {

	@Id
	@GeneratedValue(strategy = GenerationType.AUTO)
	private String bookId;
	
	@NotNull(message = "Name Needed")
	@Column(name="Book-Name", length=50)
	private String bookName;
	@NotNull(message = "Author Name Needed")
	@Column(name="Author-Name", length=30)
	private String bookAuthor;
	
	@Column(name="Discount Message", length=150)
	private String discountMessage;
	
	@NotNull(message = "Stock cannot be empty")
	@Column(name="Book-Name", length=150)
	private Long bookStock;
	
	@NotNull(message = "Price cannot be needed")
	@Column(name="Book-Price", length=8)
	private Long bookPrice;

}
